{
  "name": "@tang/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "pnpm build && node dist/server.js",
    "typecheck": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/server.js",
    "test": "vitest run -c ./vitest.config.ts",
    "drizzle:generate": "drizzle-kit generate --config drizzle.config.js",
    "drizzle:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@tang/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "express": "^4.18.2",
    "dotenv": "^10.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-kit": "^0.31.10",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.11.0",
    "sharp": "^0.34.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "tsx": "^1.0.0"
  }
}
